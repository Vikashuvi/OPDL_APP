<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/security_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/opdl_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Security Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:id="@+id/security_indicator"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@color/opdl_performance_optimal"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Security Information"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/opdl_on_surface" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_baseline_security_24"
                android:tint="@color/opdl_performance_optimal" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/opdl_divider"
            android:layout_marginBottom="12dp" />

        <!-- Security Details Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="1"
            android:rowCount="5"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true">

            <!-- Encryption Status -->
            <TextView
                android:id="@+id/encryption_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Encrypted Channel"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/opdl_performance_optimal"
                android:layout_row="0"
                android:layout_column="0" />

            <!-- Handshake Time -->
            <TextView
                android:id="@+id/handshake_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Handshake: 45 ms"
                android:textSize="14sp"
                android:textColor="@color/opdl_on_surface"
                android:layout_row="1"
                android:layout_column="0" />

            <!-- Cipher Suite -->
            <TextView
                android:id="@+id/cipher_suite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cipher: TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384"
                android:textSize="14sp"
                android:textColor="@color/opdl_on_surface"
                android:layout_row="2"
                android:layout_column="0" />

            <!-- Certificate Status -->
            <TextView
                android:id="@+id/certificate_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Certificate: Verified"
                android:textSize="14sp"
                android:textColor="@color/opdl_on_surface"
                android:layout_row="3"
                android:layout_column="0" />

            <!-- Session Key -->
            <TextView
                android:id="@+id/session_key_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Session Key: Established"
                android:textSize="14sp"
                android:textColor="@color/opdl_on_surface"
                android:layout_row="4"
                android:layout_column="0" />

        </GridLayout>

        <!-- Security Summary -->
        <TextView
            android:id="@+id/security_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 Secure Connection | AES-256-GCM"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="@color/opdl_text_secondary"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:background="@drawable/opdl_divider" />

    </LinearLayout>

</androidx.cardview.widget.CardView>